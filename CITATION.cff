cff-version: 1.2.0
message: "If you use this repository, please cite it using the metadata from this file."
title: "GeoClimate-FusionLLM: Explainable Multi-Modal Environmental Early-Warning Forecasting"
authors:
  - family-names: "Ahmed"
    given-names: "Shaheen Mohammed Saleh"
    orcid: "https://orcid.org/0000-0002-9289-128X"
repository-code: "https://github.com/SHAHEENGEOLO/GeoClimate-FusionLLM"
url: "https://github.com/SHAHEENGEOLO/GeoClimate-FusionLLM"
license: "MIT"
version: "1.0.3"
date-released: "2026-05-16"
abstract: "GeoClimate-FusionLLM is a reproducible Python repository for explainable environmental early-warning forecasting using Baghdad 2019-2024 climate data. The workflow includes leakage-safe preprocessing, multimodal feature engineering, classical forecasting baselines, deep-learning models, ablation experiments, parameter-count analysis, multi-seed robustness testing, extreme-temperature evaluation, explainability outputs, and LLM/RAG-style environmental warning report generation."
keywords:
  - "climate forecasting"
  - "environmental early warning"
  - "multimodal data fusion"
  - "deep learning"
  - "explainable AI"
  - "extreme temperature"
  - "Baghdad"
  - "GeoClimate-FusionLLM"
